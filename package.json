{
  "name": "room-service-js",
  "version": "1.0.0",
  "description": "JavaScript/TypeScript SDK for RoomService gRPC API - Build real-time multiplayer games easily!",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "generated",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build-proto && npm run build-ts",
    "build-proto": "bash scripts/build-proto.sh",
    "build-ts": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.js",
    "prepublishOnly": "npm run build",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "demo:setup": "bash scripts/setup-demo.sh",
    "demo:tictactoe": "cd examples/tic-tac-toe && npm start"
  },
  "keywords": [
    "roomservice",
    "grpc",
    "realtime",
    "multiplayer",
    "gaming",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/room-service-js.git"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.8.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
